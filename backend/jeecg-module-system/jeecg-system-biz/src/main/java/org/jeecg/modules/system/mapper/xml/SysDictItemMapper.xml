<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.system.mapper.SysDictItemMapper">

    <select id="selectValueByCode" resultType="org.jeecg.modules.system.entity.SysDictItem">
        SELECT * FROM sys_dict_item WHERE item_text = #{code}
    </select>
    <select id="queryValueByDictCode" resultType="org.jeecg.modules.system.entity.SysDictItem">
        SELECT *
        from sys_dict_item
        where dict_id = (SELECT id from sys_dict where dict_code = #{code})
    </select>
</mapper>
