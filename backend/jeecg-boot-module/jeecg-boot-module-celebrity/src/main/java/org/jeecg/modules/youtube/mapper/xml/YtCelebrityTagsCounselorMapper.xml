<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.youtube.mapper.YtCelebrityTagsCounselorMapper">
    <!-- ******************* 提取公共部分查询条件 ******************** -->

    <!-- 组合列表查询条件 -->
    <!-- 查询网红标签顾问分配明细查询条件(Where) -->
    <sql id="AllotListQueryConditions">
        <!-- <include refid="kol.common.isHighFollowerCountCondition"><property name="alias" value="yc"/></include> -->
        <include refid="kol.common.tagListInCondition"/>
        <include refid="kol.common.uniqueIdCondition"><property name="uniqueId" value="yctc.username"/></include>
        <include refid="kol.common.countryCodeCondition"><property name="alias" value="yc"/></include>
        <include refid="kol.common.counselorIdCondition"><property name="alias" value="yctc"/></include>
        <include refid="kol.common.isHasEmailCondition"><property name="alias" value="yc"/></include>
        <include refid="kol.common.emailCondition"><property name="alias" value="yc"/></include>
        <include refid="kol.common.videoStandardCountCondition"><property name="alias" value="yc"/></include>
        <include refid="kol.common.isPrivateKolConditionNew"/>
        <include refid="kol.common.followerCountCondition" ><property name="followerCount" value="yc.followers_num"/></include>
        <include refid="kol.common.allotTimeCondition"><property name="alias" value="yctc"/></include>
<!--        <include refid="kol.common.privatePlatformTypeCondition"><property name="platformType" value="1"/></include>-->
    </sql>

    <!-- ********************** 以下为业务查询部分 ********************** -->


    <!-- 获取Instagram标签网红分配历史明细视图模型数据列表 -->
    <select id="getTagAllottedList" resultType="org.jeecg.modules.kol.model.KolTagAllotModel">
        <include refid="kol.common.celebrityPrivateCondition">
            <property name="alias" value="1"/>
        </include>
        SELECT yctc.id,
        yctc.youtube_celebrity_tags_id as tag_id,
        yctc.account,
        yctc.username AS unique_id,
        yctc.tag_name,
        yctc.tag_type,
        yctc.counselor_id,
        yctc.counselor_name,
        yctc.allot_time,
        yctc.allot_log_detail_id,
        yc.country,
        yc.description AS signature,
        yc.followers_num AS author_follower_count,
        yc.video_sample_count,
        yc.video_standard_count,
        yc.email,
        yc.avatar_url AS author_avatar_url,
        cp.id AS celebrity_private_id,
        1 AS platform_type,
        kp.product_name
        FROM youtube_celebrity_tags_counselor AS yctc
        LEFT JOIN youtube_celebrity AS yc ON yc.account = yctc.account
        <include refid="kol.common.celebrityPrivateJoinCondition">
            <property name="alias" value="yctc.account"/>
            <property name="account" value="yctc.username"/>
        </include>
        LEFT JOIN kol_product kp ON yctc.product_id = kp.id
        <where>
            <include refid="AllotListQueryConditions"/>
            <if test="searchModel.productId != null and searchModel.productId != ''">
                and yctc.product_id = #{searchModel.productId}
            </if>
        </where>
        order by yctc.allot_time desc
    </select>
    <select id="getTagAllottedListCount" resultType="int">
        <include refid="kol.common.celebrityPrivateCondition">
            <property name="alias" value="1"/>
        </include>
        SELECT count(1)
        FROM youtube_celebrity_tags_counselor AS yctc
        LEFT JOIN youtube_celebrity AS yc ON yc.account = yctc.account
        <include refid="kol.common.celebrityPrivateJoinCondition">
            <property name="alias" value="yctc.account"/>
            <property name="account" value="yc.username"/>
        </include>
        LEFT JOIN kol_product kp ON yctc.product_id = kp.id
        <where>
            <include refid="AllotListQueryConditions"/>
            <if test="searchModel.productId != null and searchModel.productId != ''">
                and yctc.product_id = #{searchModel.productId}
            </if>
        </where>
    </select>

    <select id="getCelebrityTagsList" resultType="org.jeecg.modules.youtube.entity.YoutubeCelebrityTagsCounselor">
        select yctc.account,
        yctc.tag_name,
        yctc.tag_type,
        yctc.allot_time
        FROM youtube_celebrity_tags_counselor AS yctc
        join ${tempTableName} t on yctc.account = t.unique_id
        <where>
            <if test="searchModel.countryCode != null and searchModel.countryCode != ''">
                and yctc.country = #{searchModel.countryCode}
            </if>
            <if test="searchModel.productId != null and searchModel.productId != ''">
                and yctc.counselor_id = #{searchModel.counselorId}
                and yctc.product_id = #{searchModel.productId}
            </if>
        </where>
    </select>

    <select id="getBrandListByCounselorId" resultType="org.jeecg.modules.kol.entity.KolBrand">
        SELECT kb.id, kb.brand_name
        FROM youtube_celebrity_tags_counselor yctc
        JOIN kol_product kp ON kp.id = yctc.product_id
        JOIN kol_brand kb ON kb.id = kp.brand_id
        WHERE yctc.counselor_id = #{counselorId} AND kb.is_delete = 0
        GROUP BY yctc.product_id
    </select>
</mapper>