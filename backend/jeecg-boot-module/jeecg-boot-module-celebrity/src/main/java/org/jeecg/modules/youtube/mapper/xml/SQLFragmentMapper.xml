    <!-- 网红标签表关联条件 -->
    <sql id="kolTagsJoinCondition">
        LEFT JOIN youtube_celebrity_tags AS yct
        ON yc.account = yct.account
    </sql>
    <!-- 个人签名查询条件 -->
    <sql id="signatureCondition">
        <if test="searchModel.signatureKeyword != null and searchModel.signatureKeyword != ''">
            and yc.description like '%${searchModel.signatureKeyword}%'
        </if>
    </sql>

    <!-- 网红账号关联查询条件 -->
    <sql id="uniqueIdJoinCondition">
        <if test="searchModel.uniqueId != null and searchModel.uniqueId != ''">
            JOIN
            <foreach collection="searchModel.uniqueId.split(',')" item="item" open="("
                     separator=" UNION ALL " close=")">
                SELECT #{item} AS uniqueId
            </foreach>
            AS yc_uniqueId ON yc.username = yc_uniqueId.uniqueId
        </if>
    </sql>

</mapper>
