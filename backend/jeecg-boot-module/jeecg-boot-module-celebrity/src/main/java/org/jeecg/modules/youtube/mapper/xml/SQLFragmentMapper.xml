<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="yt.common">
    <!-- 标签关联查询条件 -->
    <sql id="tagListJoinCondition">
        <if test="searchModel.tagNameList != null and searchModel.tagNameList.size() > 0">
            JOIN
            (
            SELECT yc.account FROM youtube_celebrity_tags AS yc
            JOIN
            <if test="searchModel.tempTableName == null or searchModel.tempTableName == ''">
                (
                <include refid="kol.common.tagNameListForeach"/>
                ) AS tags ON yc.tag_name = tags.tag_name
            </if>
            <if test="searchModel.tempTableName != null and searchModel.tempTableName != ''">
                ${searchModel.tempTableName} AS tags ON yc.tag_name = tags.tag_name
            </if>
            join youtube_celebrity ytc on ytc.account = yc.account
            <if test="searchModel.productId != null and searchModel.productId != ''">
                left join kol_tag_product ktp on yc.tag_name = ktp.tag_name and ktp.platform_type = 1
            </if>
            <where>
                <include refid="kol.common.countryCodeCondition">
                    <property name="alias" value="yc"/>
                </include>
                <include refid="kol.common.tagTypeCondition">
                    <property name="alias" value="yc"/>
                </include>
                <if test="searchModel.productId != null and searchModel.productId != ''">
                    <include refid="kol.common.productIdCondition">
                        <property name="alias" value="ktp"/>
                    </include>
                    <include refid="kol.common.brandIdCondition">
                        <property name="alias" value="ktp"/>
                    </include>
                </if>
            </where>
            group by yc.account
            )
            yct_tag ON yct_tag.account = yc.account
        </if>
    </sql>

