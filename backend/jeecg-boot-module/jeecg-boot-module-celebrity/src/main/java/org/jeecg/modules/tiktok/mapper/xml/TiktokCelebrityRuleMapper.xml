<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.tiktok.mapper.TiktokCelebrityRuleMapper">

    <select id="getMinNum" resultType="java.lang.Integer">
        SELECT min(min_num)
        FROM `tiktok_celebrity_rule`
        where platform_type = #{platformType}
    </select>
</mapper>