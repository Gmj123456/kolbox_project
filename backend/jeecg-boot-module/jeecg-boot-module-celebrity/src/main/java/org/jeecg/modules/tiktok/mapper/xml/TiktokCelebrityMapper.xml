    <select id="getCelebrityScreeningList" resultType="org.jeecg.modules.kol.model.KolCelebrityModel">
        SELECT tc.id AS id,
        tc.unique_id AS account,
        tc.author_id,
        tc.nickname AS username,
        tc.author_avatar_url AS avatarUrl,
        tc.nickname AS fullName,
        tc.email,
        tc.signature AS description,
        tc.author_following_count AS followingCount,
        tc.author_follower_count AS followerCount,
        tc.author_video_count AS postCount,
        tc.play_avg_num AS avgPlayCount,
        tc.is_connectivity AS avgCommentCount,
        stc.country,
        tc.gender,
        tc.bio_link AS website,
        tc.bio_link AS linktree,
        tc.video_sample_count,
        tc.video_standard_count,
        tc.video_create_time_last AS lastVideoCreateTime,
        tc.video_data,
        tc.create_time AS createTime,
        tc.update_by AS updatedBy,
        tc.update_time AS updateTime,
        tc.play_avg_num,
        2 as platform_type,
        tc.median_views
        <if test="searchModel.isPrivateKol != null">
            ,cp.id AS celebrity_private_id
        </if>
        FROM tiktok_celebrity tc
        <!-- 私有库 -->
        <if test="searchModel.isPrivateKol == 1">
            INNER JOIN store_celebrity_private cp ON cp.account = tc.unique_id AND cp.platform_type = 2
        </if>
        <if test="searchModel.isPrivateKol == 0">
            LEFT JOIN store_celebrity_private cp ON cp.account = tc.unique_id AND cp.platform_type = 2
        </if>
        LEFT JOIN store_country stc on tc.country = stc.short_code
        <where>
            <if test="searchModel.isPrivateKol == 0">
                AND cp.id IS NULL
            </if>
            <!-- 标签 / 商品 / 国家过滤 -->
            <if test="searchModel.tagNameList != null and searchModel.tagNameList.size() > 0">
                and EXISTS (
                SELECT 1
                FROM tiktok_celebrity_tags tct

                <!-- tag 列表 -->
                <if test="searchModel.tempTableName == null or searchModel.tempTableName == ''">
                    JOIN (
                    <include refid="kol.common.tagNameListForeach"/>
                    ) tags ON tct.tag_name = tags.tag_name
                </if>
                <if test="searchModel.tempTableName != null and searchModel.tempTableName != ''">
                    JOIN ${searchModel.tempTableName} tags ON tct.tag_name = tags.tag_name
                </if>
                WHERE tct.author_id = tc.author_id
                <include refid="kol.common.countryCodeCondition">
                    <property name="alias" value="tct"/>
                </include>

                <include refid="kol.common.tagTypeCondition">
                    <property name="alias" value="tct"/>
                </include>

                <!-- 商品过滤：使用嵌套 EXISTS -->
                <if test="searchModel.productId != null and searchModel.productId != ''">
                    AND EXISTS (
                    SELECT 1
                    FROM kol_tag_product ktp
                    WHERE ktp.tag_name = tct.tag_name
                    AND ktp.platform_type = 2
                    <include refid="kol.common.productIdCondition">
                        <property name="alias" value="ktp"/>
                    </include>
                    )
                </if>
                )
            </if>
            <include refid="TkListQueryConditions"/>
            <include refid="kol.common.linktreeCondition">
                <property name="alias" value="tc.bio_link"/>
            </include>
            <!-- uniqueId 精确过滤 -->
            <if test="searchModel.uniqueId != null and searchModel.uniqueId != ''">
                AND tc.unique_id IN
                <foreach collection="searchModel.uniqueId.split(',')" item="item"
                         open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>

            <!-- email 精确过滤 -->
            <if test="searchModel.emailKeyword != null and searchModel.emailKeyword != '' and searchModel.isHasEmail != 0">
                AND tc.email IN
                <foreach collection="searchModel.emailKeyword.split(',')" item="item"
                         open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
        </where>
        <if test="searchModel.attributeIds!=null and searchModel.attributeIds!=''">
            ORDER BY tc.update_time DESC
        </if>
    </select>

